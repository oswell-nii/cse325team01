@using TodoApp.Models
@using TodoApp.Models.Enums

<div class="task-card @(Task.IsCompleted ? "completed" : "")">
    <div class="task-card-header">
        <div class="task-title-group d-flex align-items-center">
            <form method="post" action="/api/tasks/toggle/@Task.Id" class="m-0 p-0 me-2 d-flex align-items-center">
                <AntiforgeryToken />
                <button type="submit" class="btn-icon task-checkbox-btn p-0 m-0 d-flex align-items-center" style="width: 1.25rem; height: 1.25rem; border: 1px solid #ced4da; border-radius: 4px; background: @(Task.IsCompleted ? "var(--primary-color)" : "white"); justify-content: center;">
                    @if(Task.IsCompleted)
                    {
                        <span style="color: white; font-size: 0.8rem;">✓</span>
                    }
                </button>
            </form>
            <h4 class="task-title mb-0 @(Task.IsCompleted ? "text-strikethrough text-muted" : "")">@Task.Title</h4>
        </div>
        <div class="task-actions d-flex align-items-center">
            <a href="/tasks/edit/@Task.Id" class="btn-icon btn-edit text-decoration-none me-2" title="Edit">✏️</a>
            <form method="post" action="/api/tasks/delete/@Task.Id" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this task?');">
                <AntiforgeryToken />
                <button type="submit" class="btn-icon btn-delete" title="Delete">🗑️</button>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Task.Description))
    {
        <p class="task-description text-muted">@Task.Description</p>
    }

    <div class="task-footer">
        <div class="task-badges">
            <span class="badge badge-category category-@Task.Category.ToString().ToLower()">
                @Task.Category.ToString()
            </span>
            <span class="badge badge-priority priority-@Task.Priority.ToString().ToLower()">
                @Task.Priority.ToString() Priority
            </span>
        </div>

        @if (Task.DueDate.HasValue)
        {
            <div class="task-due-date @(IsOverdue ? "text-danger fw-bold" : "text-muted")">
                📅 @FormatDueDate(Task.DueDate.Value)
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public TaskItem Task { get; set; } = null!;

    private bool IsOverdue => !Task.IsCompleted && Task.DueDate.HasValue && Task.DueDate.Value.Date < DateTime.UtcNow.Date;

    private string FormatDueDate(DateTime date)
    {
        var today = DateTime.UtcNow.Date;
        if (date.Date == today)
            return "Today";
        if (date.Date == today.AddDays(1))
            return "Tomorrow";
        if (date.Date == today.AddDays(-1))
            return "Yesterday";

        return date.ToString("MMM dd, yyyy");
    }
}
