@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 auth-status">
            <AuthorizeView>
                <Authorized>
                    <div class="d-flex align-items-center gap-3">
                        <span class="user-greeting">Hello, @context.User.Identity?.Name!</span>
                        <form action="Account/Logout" method="post" class="d-inline" @formname="LogoutForm">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="" />
                            <button type="submit" class="btn btn-link nav-link px-3 text-primary border-0 bg-transparent">Logout</button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
